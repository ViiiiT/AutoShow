.DS_Store
__pycache__/
*.py[cod]

# Local media and generated audio are intentionally not stored in git.
download/*
media/*
output/*

# Keep the expected project folders.
!download/.gitkeep
!media/assets/
media/assets/*
!media/assets/.gitkeep
!media/music/
media/music/*
!media/music/.gitkeep
!output/.gitkeep
